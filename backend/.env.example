# ─────────────────────────────────────────────────────────────────────────────
# JBLines Email Hub — Backend Environment Variables
# Copy this file to .env for local development.
# In Render: add these in the "Environment" tab of your service.
# ─────────────────────────────────────────────────────────────────────────────

# Database (provided automatically by Render/Neon — paste your Neon connection string)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# Google Service Account (paste the entire JSON as a single line, or use the file path)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json

# All company inboxes to sync (comma-separated)
COMPANY_INBOXES=sales@jblines.com,support@jblines.com,billing@jblines.com,info@jblines.com

# Private inboxes — raw email content hidden from staff, only admins see full threads
PRIVATE_INBOXES=mark@jblines.com,ben@jblines.com

# How many days of email history to pull on first sync (180 = 6 months)
SYNC_DAYS_BACK=180

# Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# JWT secret — generate a long random string (e.g. openssl rand -hex 32)
JWT_SECRET_KEY=replace-with-a-long-random-secret-string

# One-time setup password — used only to create the first admin account
SETUP_SECRET=choose-a-temporary-setup-password
